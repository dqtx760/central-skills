# Gemini 网页接口鉴权 cookie
# 获取步骤：
#   1. 用浏览器(建议无痕窗口)打开 https://gemini.google.com 并登录 Google 账号
#   2. 按 F12 打开开发者工具，切到 Application(应用) -> Cookies -> https://gemini.google.com
#   3. 找到下面两个 cookie，复制它们的 Value 填到这里
#
#   __Secure-1PSID      -> GEMINI_1PSID
#   __Secure-1PSIDTS    -> GEMINI_1PSIDTS
#
# 注意：
#   - 这两个 cookie 等同于你的登录态，切勿提交到 git 或分享给别人
#   - __Secure-1PSIDTS 有效期较短，但脚本运行期间会自动刷新
#   - 用完后建议在浏览器里登出，让这个 cookie 失效

GEMINI_1PSID=
GEMINI_1PSIDTS=

# 生图默认输出目录（不配则用 D:\data\images\Article-illustrations）
IMAGE_OUTPUT_DIR=

# PicGo 上传配置（方式A：调本地 PicGo 客户端 HTTP 接口）
#   1. 打开 PicGo 客户端 -> 设置 -> 设置 Server -> 开启
#   2. 记下端口（默认 36677）和可选的鉴权 token
#   3. PICGO_AUTO_UPLOAD=1 时，生图保存后会自动上传到当前选中的图床并返回外链
PICGO_SERVER=http://127.0.0.1:36677
PICGO_TOKEN=
PICGO_AUTO_UPLOAD=1
